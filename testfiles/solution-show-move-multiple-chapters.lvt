\documentclass{exam-zh}

\input{regression-test}

\examsetup{solution/show-solution=show-move}

\begin{document}
\START

\chapter{First paper}

\begin{problem}
  First problem.
\end{problem}
\begin{solution}
  \TYPE{first-answer=rendered}
  First solution.
\end{solution}

\chapter{Second paper}

